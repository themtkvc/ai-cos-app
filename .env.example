# ═══════════════════════════════════════════════════
# AI CHIEF OF STAFF — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ═══════════════════════════════════════════════════

# Supabase — get from https://app.supabase.com → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic Claude API — get from https://console.anthropic.com
# NOTE: In production, this should be on your backend (Node.js server), not frontend
# For the initial version, we proxy through a simple backend
REACT_APP_CLAUDE_API_KEY=your-claude-api-key-here
